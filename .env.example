# ==========================================
# NetSec Analyzer - Environment Configuration
# ==========================================

# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration  
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Ollama Local Configuration
# Optional: Only needed if running Ollama on different host/port
# Default: http://localhost:11434
VITE_OLLAMA_BASE_URL=http://localhost:11434

# ==========================================
# Setup Instructions:
# ==========================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Replace the placeholder values with your actual API keys
# 3. At least one API provider must be configured for the app to work
# 4. Restart the development server after changing environment variables

# ==========================================
# API Provider Notes:
# ==========================================
# - Gemini: Free tier available, good for general analysis
# - OpenAI: Paid service, excellent for structured security analysis  
# - Ollama: Local hosting, no API key required, requires local installation

# ==========================================
# Security Notes:
# ==========================================
# - Never commit .env files to version control
# - Keep API keys secure and private
# - Use environment-specific keys for development vs production